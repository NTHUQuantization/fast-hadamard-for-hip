ninja_required_version = 1.3
cxx = c++
nvcc = /opt/rocm-7.2.0/bin/hipcc

cflags = -pthread -B /user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/compiler_compat -fno-strict-overflow -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/include -fPIC -O2 -isystem /user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/include -fPIC -I/user/undergraduate/tschen25/fast-hadamard-transform -I/opt/rocm-7.2.0/include -I/user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/lib/python3.12/site-packages/torch/include -I/user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/include/python3.12 -c
post_cflags = -D__HIP_PLATFORM_AMD__=1 -DUSE_ROCM=1 -DHIPBLAS_V2 -fPIC -D__HIP_PLATFORM_AMD__=1 -DUSE_ROCM=1 -DHIPBLAS_V2 -fPIC -O3 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=fast_hadamard_transform_hip -std=c++17
cuda_cflags = -I/user/undergraduate/tschen25/fast-hadamard-transform -I/opt/rocm-7.2.0/include -I/user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/lib/python3.12/site-packages/torch/include -I/user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/user/undergraduate/tschen25/anaconda3/envs/fht_rocm_env/include/python3.12 -c
cuda_post_cflags = -D__HIP_PLATFORM_AMD__=1 -DUSE_ROCM=1 -DHIPBLAS_V2 -fPIC -DCUDA_HAS_FP16=1 -D__HIP_NO_HALF_OPERATORS__=1 -D__HIP_NO_HALF_CONVERSIONS__=1 -DHIP_ENABLE_WARP_SYNC_BUILTINS=1 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=fast_hadamard_transform_hip --offload-arch=gfx900 --offload-arch=gfx906 --offload-arch=gfx908 --offload-arch=gfx90a --offload-arch=gfx942 --offload-arch=gfx1030 --offload-arch=gfx1100 --offload-arch=gfx1101 --offload-arch=gfx1102 --offload-arch=gfx1200 --offload-arch=gfx1201 --offload-arch=gfx950 --offload-arch=gfx1150 --offload-arch=gfx1151 -fno-gpu-rdc -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags







build /user/undergraduate/tschen25/fast-hadamard-transform/build/temp.linux-x86_64-cpython-312/csrc/fast_hadamard_transform_cuda_to_hip.o: cuda_compile /user/undergraduate/tschen25/fast-hadamard-transform/csrc/fast_hadamard_transform_cuda_to_hip.cu
build /user/undergraduate/tschen25/fast-hadamard-transform/build/temp.linux-x86_64-cpython-312/csrc/fast_hadamard_transform_to_hip.o: compile /user/undergraduate/tschen25/fast-hadamard-transform/csrc/fast_hadamard_transform_to_hip.cpp








